###############################################################################
# Dockerfile.test-ubuntu
#
# Validates install-minimal.sh on Ubuntu 22.04 using the LOCAL repo.
#
# Build:
#   docker build --build-arg GITHUB_PAT="$GITHUB_PAT" \
#     -f podman/Dockerfile.test-ubuntu -t dotfiles-test-ubuntu .
#
# Run:
#   docker run --rm dotfiles-test-ubuntu
#
# The image copies your working tree into the container (no git clone from
# GitHub), so you can test changes before pushing.
###############################################################################

ARG GIT_PREFIX=/home/testuser/.local
ARG GIT_VERSION=2.51.0

# ---- Stage 1: build a static git (reused from existing Dockerfile) ----------
FROM alpine:3.19 AS git-builder
ARG GIT_PREFIX
ARG GIT_VERSION

RUN apk add --no-cache \
    make gcc musl-dev \
    openssl-dev openssl-libs-static \
    zlib-dev zlib-static \
    ca-certificates wget perl

RUN CURL_VERSION="8.12.1" \
 && wget -q "https://curl.se/download/curl-${CURL_VERSION}.tar.gz" -O /tmp/curl.tar.gz \
 && tar -xzf /tmp/curl.tar.gz -C /tmp \
 && cd /tmp/curl-${CURL_VERSION} \
 && ./configure \
      --prefix=/opt/curl \
      --disable-shared --enable-static \
      --with-openssl \
      --without-nghttp2 --without-brotli --without-libpsl \
      --without-libidn2 --without-librtmp --without-libssh2 \
      --without-zstd \
      --disable-ldap --disable-rtsp \
      --disable-ftp --disable-smtp --disable-pop3 --disable-imap --disable-dict \
 && make -j$(nproc) install \
 && rm -rf /tmp/curl-${CURL_VERSION} /tmp/curl.tar.gz

RUN wget -q "https://mirrors.edge.kernel.org/pub/software/scm/git/git-${GIT_VERSION}.tar.gz" \
         -O /tmp/git.tar.gz \
 && tar -xzf /tmp/git.tar.gz -C /tmp \
 && cd /tmp/git-${GIT_VERSION} \
 && CURL_STATIC_LIBS=$(/opt/curl/bin/curl-config --static-libs) \
 && make NO_GETTEXT=1 NO_TCLTK=1 NO_ICONV=1 NO_EXPAT=1 NO_REGEX=NeedsStartEnd \
         CURL_CONFIG=/opt/curl/bin/curl-config \
         CFLAGS="-I/opt/curl/include" \
         LDFLAGS="-static -L/opt/curl/lib" \
         CURL_LIBCURL="$CURL_STATIC_LIBS" \
         prefix="${GIT_PREFIX}" install \
 && strip "${GIT_PREFIX}/bin/git"

# ---- Stage 2: Ubuntu 22.04 + install-minimal.sh ----------------------------
FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV HOME=/home/testuser

# Build deps that install-minimal.sh may need (htop build-from-source, etc.)
RUN apt-get update && apt-get install -y \
    curl \
    git \
    make \
    gcc \
    autoconf \
    automake \
    libncurses-dev \
    xz-utils \
    unzip \
    && rm -rf /var/lib/apt/lists/*

# Non-root user — matches real-world usage (no sudo)
RUN useradd -m -s /bin/bash testuser
USER testuser
WORKDIR /home/testuser

# Copy the LOCAL working tree (not a git clone)
COPY --chown=testuser:testuser . /home/testuser/.dotfiles

# Pre-place a static git so install-minimal.sh doesn't need to compile it
ARG GIT_PREFIX
COPY --from=git-builder --chown=testuser:testuser ${GIT_PREFIX}/bin/git ${GIT_PREFIX}/bin/git
COPY --from=git-builder --chown=testuser:testuser ${GIT_PREFIX}/libexec/git-core ${GIT_PREFIX}/libexec/git-core

# Initialize .dotfiles as a git repo so status checks work
RUN cd /home/testuser/.dotfiles && git init && git add -A && git commit -m "test snapshot" --allow-empty

# Run install-minimal.sh non-interactively
# The script has several read prompts; feed them all "y" + Enter
ARG GITHUB_PAT
RUN export PATH="$HOME/.local/bin:$PATH" \
 && printf '\ny\ny\ny\ny\ny\n' | GITHUB_PAT="${GITHUB_PAT}" bash /home/testuser/.dotfiles/install-minimal.sh --force-update 2>&1 || true

# Copy the test script
COPY --chown=testuser:testuser podman/validate.sh /home/testuser/validate.sh
RUN chmod +x /home/testuser/validate.sh

CMD ["/bin/bash", "/home/testuser/validate.sh"]
